# =========================
# Core (Required in production)
# =========================
SECRET_KEY=change-me-to-a-long-random-secret
JWT_SECRET=change-me-to-a-different-long-random-secret

# Hidden admin login path (without domain)
# Example: /secure-admin-portal-9x7
ADMIN_ENTRY_PATH=/secure-admin-portal-9x7

# =========================
# App runtime
# =========================
JWT_EXP_HOURS=48
HOST=127.0.0.1
PORT=5000

# =========================
# Admin registration protection (optional)
# If set, admin registration requires this code.
# =========================
ADMIN_REGISTRATION_CODE=

# =========================
# UPI payment (optional)
# =========================
UPI_ID=
UPI_NAME=Healthcare Pharmacy

# =========================
# Stripe (optional)
# =========================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# =========================
# Razorpay (optional)
# =========================
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
